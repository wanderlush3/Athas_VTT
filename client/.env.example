# Athas VTT Client — Environment Variables
#
# These are build-time overrides. For most users, the lobby's
# "Server Connection" field is the easiest way to set the server URL.

# Server URL (build-time default — overridden at runtime by lobby input)
# NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# API URL (auto-derived from server URL; only set if server API is at a different path)
# NEXT_PUBLIC_API_URL=http://localhost:3000/api
