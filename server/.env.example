# Athas VTT Server — Environment Variables

# Database connection (SQLite default)
DATABASE_URL="file:../../prisma/athas.db"

# Server
# PORT=3000
# HOST=0.0.0.0

# CORS — Which client origins to allow.
# Single origin:       CLIENT_ORIGIN=http://localhost:3001
# Multiple origins:    CLIENT_ORIGIN=http://localhost:3001,http://192.168.1.50:3001
# Allow all (default): CLIENT_ORIGIN=*
# CLIENT_ORIGIN=*

# NODE_ENV=development

# Uploads
# UPLOAD_DIR=./uploads

# Logging (trace, debug, info, warn, error, fatal)
# LOG_LEVEL=debug
